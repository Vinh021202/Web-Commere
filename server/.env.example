# Copy this file to .env and fill your secret keys
# Do NOT commit your real .env to source control

# Your Stripe secret key (starts with sk_test_ or sk_live_)
STRIPE_SECRET=sk_test_your_secret_here

# Client URL used to build success/cancel redirect links
VITE_CLIENT_URL=http://localhost:5173

# Optional additional frontend URLs
CLIENT_URLS=http://localhost:5173,https://your-frontend.vercel.app
